VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# API.Bible — required for NKJV and NET translations
# Get your key at https://scripture.api.bible/
# Find Bible IDs by calling: GET https://rest.api.bible/v1/bibles  (with api-key header)
VITE_API_BIBLE_KEY=your-api-bible-key-here
VITE_BIBLE_ID_NKJV=   # look up from GET https://rest.api.bible/v1/bibles once NKJV license is approved
# NET Bible uses labs.bible.org — no key needed

# Cloudflare Pages Functions — set these in the Cloudflare Pages dashboard
# under Settings > Environment Variables (NOT in .env — these are server-side only)
# CLOUDFLARE_ACCOUNT_ID=your-account-id
# CLOUDFLARE_STREAM_API_TOKEN=your-stream-api-token-with-stream-edit-permissions
