VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Cloudflare Pages Functions — set ALL of these in the Cloudflare Pages dashboard
# under Settings > Environment Variables (NOT prefixed with VITE_ — server-side only)
# CLOUDFLARE_ACCOUNT_ID=your-account-id
# CLOUDFLARE_STREAM_API_TOKEN=your-stream-api-token-with-stream-edit-permissions

# Bible passage proxy (functions/api/passage.js)
# Get your API.Bible key at https://scripture.api.bible/
# Find Bible IDs via: GET https://rest.api.bible/v1/bibles  (with api-key header)
API_BIBLE_KEY=your-api-bible-key-here
BIBLE_ID_KJV=de4e12af7f28f599-01
BIBLE_ID_WEB=9879dbb7cfe39e4d-01
BIBLE_ID_ASV=06125adad2d5898a-01
BIBLE_ID_NKJV=63097d2a0a2f7db3-01
# NET Bible uses labs.bible.org — no ID needed
